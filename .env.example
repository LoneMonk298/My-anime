# Anime Record Site local environment example
# Copy this file to .env only for your own notes; Spring Boot reads these values
# from OS environment variables or command-line arguments.

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=anime_record_site
DB_USERNAME=ai_user
DB_PASSWORD=change_me

JWT_SECRET=change-this-development-secret-at-least-32-characters
JWT_EXPIRE_HOURS=24

UPLOAD_DIR=uploads

APP_LOG_LEVEL=INFO
HIKARI_LOG_LEVEL=INFO
